# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.log.*

# Exclude sensitive vars
*.tfvars
# Except the example one if requested, but usually better to provide .example
# terraform.tfvars 

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory
.terraform.lock.hcl
